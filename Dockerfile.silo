FROM node:24-alpine
RUN apk add --no-cache git wget bash github-cli docker-cli
RUN npm install -g pnpm @anthropic-ai/claude-code @anthropic-ai/claude-agent-sdk

# Build silo from local source (via additional_contexts)
WORKDIR /build
COPY --from=silo package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY --from=silo . .
RUN pnpm build && npm pack && npm install -g wopr-network-silo-*.tgz && rm -rf /build

ENV CLI=/usr/local/lib/node_modules/@wopr-network/silo/dist/src/execution/cli.js
ENV GATES_DIR=/usr/local/lib/node_modules/@wopr-network/silo/dist/gates
COPY seed/gates/ /usr/local/lib/node_modules/@wopr-network/silo/dist/gates/
RUN chmod +x /usr/local/lib/node_modules/@wopr-network/silo/dist/gates/*.sh 2>/dev/null || true
RUN mkdir -p /data/repos /data/worktrees && chown -R node:node /data
RUN echo "node ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers
WORKDIR /app
COPY cheyenne-mountain-entrypoint.sh /usr/local/bin/entrypoint.sh
USER node
CMD ["sh", "/usr/local/bin/entrypoint.sh"]
