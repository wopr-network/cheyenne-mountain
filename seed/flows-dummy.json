{
  "flows": [
    {
      "name": "wopr-changeset",
      "description": "Dummy pipeline for testing. No gates, no onEnter hooks, minimal prompts.",
      "discipline": "engineering",
      "initialState": "architecting",
      "maxConcurrent": 4,
      "maxConcurrentPerRepo": 4,
      "createdBy": "seed:wopr-changeset"
    }
  ],
  "states": [
    {
      "name": "backlog",
      "flowName": "wopr-changeset",
      "mode": "passive"
    },
    {
      "name": "architecting",
      "flowName": "wopr-changeset",
      "agentRole": "wopr-architect",
      "modelTier": "opus",
      "mode": "active",
      "promptTemplate": "## Assignment\nIssue: {{entity.refs.linear.key}} — {{entity.refs.linear.title}}\nRepo: {{entity.refs.github.repo}}\n\n## Issue Description\n{{entity.refs.linear.description}}\n\nWrite an implementation spec. Signal spec_ready when done."
    },
    {
      "name": "coding",
      "flowName": "wopr-changeset",
      "agentRole": "wopr-coder",
      "modelTier": "sonnet",
      "mode": "active",
      "promptTemplate": "## Assignment\nIssue: {{entity.refs.linear.key}} — {{entity.refs.linear.title}}\nRepo: {{entity.refs.github.repo}}\n\nImplement the spec. Signal pr_created when done."
    },
    {
      "name": "reviewing",
      "flowName": "wopr-changeset",
      "agentRole": "wopr-reviewer",
      "modelTier": "sonnet",
      "mode": "active",
      "promptTemplate": "## Assignment\nIssue: {{entity.refs.linear.key}}\nRepo: {{entity.refs.github.repo}}\n\nReview the work. Signal clean or issues."
    },
    {
      "name": "fixing",
      "flowName": "wopr-changeset",
      "agentRole": "wopr-fixer",
      "modelTier": "sonnet",
      "mode": "active",
      "promptTemplate": "## Assignment\nIssue: {{entity.refs.linear.key}}\nRepo: {{entity.refs.github.repo}}\n\nFix the findings. Signal fixes_pushed when done."
    },
    {
      "name": "documenting",
      "flowName": "wopr-changeset",
      "agentRole": "wopr-technical-writer",
      "modelTier": "sonnet",
      "mode": "active",
      "promptTemplate": "## Assignment\nIssue: {{entity.refs.linear.key}} — {{entity.refs.linear.title}}\nRepo: {{entity.refs.github.repo}}\n\nUpdate docs if needed. Signal docs_ready when done."
    },
    {
      "name": "learning",
      "flowName": "wopr-changeset",
      "agentRole": "wopr-claude-md-writer",
      "modelTier": "haiku",
      "mode": "active",
      "promptTemplate": "## Assignment\nIssue: {{entity.refs.linear.key}} — {{entity.refs.linear.title}}\nRepo: {{entity.refs.github.repo}}\n\nExtract lessons learned. Signal learning_complete when done."
    },
    {
      "name": "stuck",
      "flowName": "wopr-changeset",
      "mode": "passive"
    },
    {
      "name": "done",
      "flowName": "wopr-changeset",
      "mode": "passive"
    }
  ],
  "nukes": [
    {
      "discipline": "engineering",
      "image": "nuke-coder",
      "onProvision": [
        {
          "command": "/app/seed/scripts/inject-credentials.sh {{nukeHost}} {{nukePort}}",
          "timeout_ms": 10000
        }
      ]
    }
  ],
  "gates": [],
  "transitions": [
    { "flowName": "wopr-changeset", "fromState": "backlog", "toState": "architecting", "trigger": "start", "priority": 0 },
    { "flowName": "wopr-changeset", "fromState": "architecting", "toState": "coding", "trigger": "spec_ready", "priority": 0 },
    { "flowName": "wopr-changeset", "fromState": "coding", "toState": "reviewing", "trigger": "pr_created", "priority": 0 },
    { "flowName": "wopr-changeset", "fromState": "reviewing", "toState": "documenting", "trigger": "clean", "priority": 0 },
    { "flowName": "wopr-changeset", "fromState": "reviewing", "toState": "fixing", "trigger": "issues", "priority": 1 },
    { "flowName": "wopr-changeset", "fromState": "fixing", "toState": "reviewing", "trigger": "fixes_pushed", "priority": 0 },
    { "flowName": "wopr-changeset", "fromState": "fixing", "toState": "stuck", "trigger": "cant_resolve", "priority": 1 },
    { "flowName": "wopr-changeset", "fromState": "documenting", "toState": "learning", "trigger": "docs_ready", "priority": 0 },
    { "flowName": "wopr-changeset", "fromState": "documenting", "toState": "stuck", "trigger": "cant_document", "priority": 1 },
    { "flowName": "wopr-changeset", "fromState": "learning", "toState": "done", "trigger": "learning_complete", "priority": 0 },
    { "flowName": "wopr-changeset", "fromState": "learning", "toState": "stuck", "trigger": "cant_learn", "priority": 1 }
  ]
}
