FROM node:24-alpine
RUN apk add --no-cache git
RUN npm install -g pnpm @wopr-network/defcon@latest
ENV CLI=/usr/local/lib/node_modules/@wopr-network/defcon/dist/src/execution/cli.js
WORKDIR /app
CMD ["sh", "-c", "SEED=${DUMMY_MODE:+/app/seed/flows-dummy.json}; node $CLI init --seed ${SEED:-/app/seed/flows.json} --db /data/defcon.db && node $CLI serve --http-only --http-host 0.0.0.0 --http-port 3001 --db /data/defcon.db"]
